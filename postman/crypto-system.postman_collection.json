    {
      "name": "2 - Limit order (1 order \u2192 match \u2192 ETH wallet)",
      "description": "Run entire folder with Collection Runner.\n\nOne limit BUY for ETH. Verifies order FILLED (matched) and ETH balance increased in wallet.\n\nlimitPrice = live bestAsk so order matches immediately when market ask <= limit.",
      "item": [
        {
          "name": "1 - Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const b = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', b.accessToken);",
                  "pm.collectionVariables.set('userId', String(b.userId));",
                  "pm.collectionVariables.set('pollAttempt', '0');"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"limit-{{$timestamp}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "2 - GET ETH price + wallet before",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('pollAttempt', '0');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('ETH price 200', () => pm.response.to.have.status(200));",
                  "const ask = parseFloat(pm.response.json().bestAskPrice);",
                  "pm.collectionVariables.set('ethBestAsk', pm.response.json().bestAskPrice);",
                  "pm.collectionVariables.set('limitBuyPrice', (ask * 1.0001).toFixed(8));",
                  "const base = pm.collectionVariables.get('baseUrl');",
                  "const token = pm.collectionVariables.get('accessToken');",
                  "pm.sendRequest({",
                  "  url: base + '/api/wallet/balances',",
                  "  method: 'GET',",
                  "  header: { Authorization: 'Bearer ' + token }",
                  "}, (err, res) => {",
                  "  pm.test('Wallet before 200', () => pm.expect(res).to.have.property('code', 200));",
                  "  const eth = res.json().balances.find(b => b.asset === 'ETH');",
                  "  pm.collectionVariables.set('ethBefore', eth.balance);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/prices/latest/ETHUSDT",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "prices",
                "latest",
                "ETHUSDT"
              ]
            }
          }
        },
        {
          "name": "3 - POST limit BUY ETH (one order)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const o = pm.response.json();",
                  "pm.collectionVariables.set('limitOrderId', String(o.id));",
                  "pm.test('Order created', () => {",
                  "  pm.expect(o.symbol).to.eql('ETHUSDT');",
                  "  pm.expect(o.side).to.eql('BUY');",
                  "});",
                  "if (o.status === 'FILLED') {",
                  "  pm.test('Order matched immediately', () => pm.expect(o.executionPrice).to.exist);",
                  "} else {",
                  "  pm.test('Order pending (will poll next step)', () => pm.expect(o.status).to.eql('PENDING'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"ETHUSDT\",\n  \"side\": \"BUY\",\n  \"quantity\": \"{{ethQty}}\",\n  \"limitPrice\": \"{{limitBuyPrice}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/limit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders",
                "limit"
              ]
            },
            "description": "limitPrice = current bestAsk \u2192 matches when ask <= limit (fills on place or within ~5s poll)."
          }
        },
        {
          "name": "4 - Verify order matched",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const attempt = parseInt(pm.collectionVariables.get('pollAttempt') || '0', 10);",
                  "if (attempt > 0) {",
                  "  const waitUntil = Date.now() + 2500;",
                  "  while (Date.now() < waitUntil) { }",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const orderId = pm.collectionVariables.get('limitOrderId');",
                  "const order = pm.response.json().find(o => String(o.id) === orderId);",
                  "pm.test('Order found', () => pm.expect(order).to.exist);",
                  "if (order.status === 'FILLED') {",
                  "  pm.test('Limit order matched (FILLED)', () => {",
                  "    pm.expect(order.status).to.eql('FILLED');",
                  "    pm.expect(order.executionPrice).to.exist;",
                  "    pm.expect(order.quoteAmount).to.exist;",
                  "  });",
                  "  pm.collectionVariables.set('pollAttempt', '0');",
                  "} else {",
                  "  const attempt = parseInt(pm.collectionVariables.get('pollAttempt') || '0', 10) + 1;",
                  "  pm.collectionVariables.set('pollAttempt', String(attempt));",
                  "  if (attempt < 12) {",
                  "    pm.execution.setNextRequest('4 - Verify order matched');",
                  "  } else {",
                  "    pm.test('Limit order matched within 60s', () => {",
                  "      pm.expect.fail('Order still ' + order.status + ' \u2014 check price scheduler is running');",
                  "    });",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/limit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders",
                "limit"
              ]
            }
          }
        },
        {
          "name": "5 - Verify ETH in wallet",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const eth = pm.response.json().balances.find(b => b.asset === 'ETH');",
                  "const ethBefore = parseFloat(pm.collectionVariables.get('ethBefore'));",
                  "const qty = parseFloat(pm.collectionVariables.get('ethQty'));",
                  "pm.test('ETH auto-transferred to wallet after match', () => {",
                  "  pm.expect(parseFloat(eth.balance)).to.be.at.least(ethBefore + qty - 0.00000001);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/wallet/balances",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "wallet",
                "balances"
              ]
            }
          }
        }
      ]
    },
